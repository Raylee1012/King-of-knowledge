# ═══════════════════════════════════════════════════════════
# 環境變數設定範本
# 複製此檔案為 .env，填入實際值後啟動伺服器
# Railway 部署時在 Variables 頁面直接設定這些值
# ═══════════════════════════════════════════════════════════

# Supabase PostgreSQL 連線字串
# 取得方式：Supabase Dashboard → Connect → Transaction pooler → 複製連線字串
# 格式：postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=https://ixxwtzkdbygjxabxhtpq.supabase.co

# 伺服器埠號（Railway 會自動注入 PORT，本機預設 3000）
PORT=3000
